# ==============================================================================
# Environment Variables for Whitelabel Ordering App
# ==============================================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
# ==============================================================================

# ------------------------------------------------------------------------------
# NextAuth Configuration
# ------------------------------------------------------------------------------
# Generate a strong random string: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-strong-random-string-here
# Base URL of the application (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Google OAuth
# ------------------------------------------------------------------------------
# Get from: https://console.developers.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID (Web application)
# 2. Add authorized redirect URI:
#    - Dev:  http://localhost:3000/api/auth/callback/google
#    - Prod: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ------------------------------------------------------------------------------
# Supabase Database (PostgreSQL)
# ------------------------------------------------------------------------------
# Get from: Supabase Dashboard → Settings → Database
# DATABASE_URL uses port 6543 (connection pooler / pgbouncer)
# DIRECT_URL uses port 5432 (direct connection, used by Prisma migrations)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ------------------------------------------------------------------------------
# Supabase Storage (S3-compatible) — for image uploads
# ------------------------------------------------------------------------------
# Get from: Supabase Dashboard → Settings → API → S3 Access Keys
# These credentials allow the app to upload and manage files via S3 protocol.
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY_ID=your-s3-access-key
SUPABASE_S3_SECRET_ACCESS_KEY=your-s3-secret-key
SUPABASE_S3_BUCKET=uploads

# ------------------------------------------------------------------------------
# Stripe Connect — for payments
# ------------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/apikeys
# Use sk_test_ / pk_test_ keys for development, sk_live_ / pk_live_ for production.
# Webhook secret is created when you register a webhook endpoint in Stripe Dashboard.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------------------------
# Resend — for magic link emails
# ------------------------------------------------------------------------------
# Get from: https://resend.com/api-keys
# EMAIL_FROM must be a verified sender address/domain in your Resend account.
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# ------------------------------------------------------------------------------
# AADE myDATA — for Greek tax invoicing
# ------------------------------------------------------------------------------
# Get from: https://www.aade.gr/mydata
# Use the development endpoint for testing; switch to production for live invoicing.
# Dev endpoint:  https://mydataapidev.aade.gr/myDATA
# Prod endpoint: https://mydatapi.aade.gr/myDATA
AADE_API_KEY=your-aade-api-key
AADE_CLIENT_ID=your-aade-client-id
AADE_ENDPOINT=https://mydataapidev.aade.gr/myDATA

# ------------------------------------------------------------------------------
# Google Maps — for address autocomplete
# ------------------------------------------------------------------------------
# Get from: https://console.cloud.google.com/google/maps-apis/credentials
# Enable Places API for this key.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
